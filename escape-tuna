end)

-- [ 3. THUẬT TOÁN ĐẢO 3D TOÀN DIỆN (DỌC - NGANG - XOẮN ỐC) ]
local function StartAdvancedEvade()
    if isEvading then return end
    isEvading = true
    
    local MyChar = LocalPlayer.Character
    local MyHRP = MyChar and MyChar:FindFirstChild("HumanoidRootPart")
    local MyHum = MyChar and MyChar:FindFirstChild("Humanoid")
    
    if not MyHRP or not MyHum then isEvading = false return end
    
    -- Bước 1: Vọt nhanh lên 1000 block chống Check-Teleport
    local startPos = MyHRP.Position
    local targetAirPos = startPos + Vector3.new(0, EVADE_HEIGHT, 0)
    
    local jumpTime = 0
    while jumpTime < 0.25 do
        jumpTime = jumpTime + RunService.Heartbeat:Wait()
        MyHRP.CFrame = CFrame.new(startPos:Lerp(targetAirPos, jumpTime / 0.25))
    end
    
    -- Bước 2: Quỹ đạo lướt hỗn loạn đan xen Dọc/Ngang/Tròn trong đúng 4 giây
    local startTime = tick()
    local count = 0
    
    while tick() - startTime < EVADE_DURATION do
        RunService.Heartbeat:Wait()
        if not MyHRP or not MyHum or MyHum.Health <= 0 then break end
        
        -- No-Clip liên tục bám map không kẹt
        for _, part in pairs(MyChar:GetChildren()) do
            if part:IsA("BasePart") then part.CanCollide = false end
        end
        
        count = count + 1
        local timePassed = tick() - startTime
        
        -- Toán học lượng giác đảo chiều liên tục
        local angleX = math.rad(count * 12)
        local angleZ = math.rad(count * 15)
        
        -- 1. Đảo Ngang (Mở rộng biên độ sang hai bên)
        local sideMove = MyHRP.CFrame.RightVector * math.sin(angleX) * ZICZAC_AMPLITUDE
        
        -- 2. Đảo Dọc (Lướt lên/về phía trước theo dạng sóng gợn)
        local forwardMove = MyHRP.CFrame.LookVector * math.cos(angleZ) * (ZICZAC_SPEED / 45)
        
        -- 3. Tạo hiệu ứng xoắn ốc hỗn loạn ở giây thứ 2 và 3 để xé nhỏ hoàn toàn Hitbox
        local spiralMove = Vector3.new(0, 0, 0)
        if timePassed > 1.5 and timePassed < 3.5 then
            spiralMove = MyHRP.CFrame.RightVector * math.cos(angleX) * (ZICZAC_AMPLITUDE / 2)
        end
        
        -- Ép dịch chuyển tuyến tính mượt từng Frame (No Fly Cheat Detection)
        MyHRP.CFrame = CFrame.new(MyHRP.Position + forwardMove + sideMove + spiralMove) * CFrame.Angles(0, math.rad(math.sin(angleX) * 20), 0)
        MyHRP.Velocity = Vector3.new(0, 0, 0)
    end
    
    isEvading = false
end

-- [ 4. PHÁT HIỆN DÍNH SÁT THƯƠNG ]
RunService.Heartbeat:Connect(function()
    if not _G.EvadeSystemActive then return end
    local MyChar = LocalPlayer.Character
    local MyHum = MyChar and MyChar:FindFirstChildOfClass("Humanoid")
    
    if MyHum then
        if MyHum.Health < lastHealth and MyHum.Health > 0 then
            task.spawn(StartAdvancedEvade)
        end
        lastHealth = MyHum.Health
    else
        lastHealth = 100
    end
end)
