-- Cơ chế ẩn/hiện console
local isOpen = false
local function ToggleConsole()
    isOpen = not isOpen
    if isOpen then
        HUD.Visible = true
        HUD:TweenSize(UDim2.new(0, 200, 0, 100), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.2, true)
    else
        HUD:TweenSize(UDim2.new(0, 0, 0, 100), Enum.EasingDirection.In, Enum.EasingStyle.Quad, 0.2, true, function()
            HUD.Visible = false
        end)
    end
end

ToggleBtn.MouseButton1Click:Connect(ToggleConsole)
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if not gameProcessed and input.KeyCode == Enum.KeyCode.K then
        ToggleConsole()
    end
end)

