-- ==================== HÀM ESCAPE BAY XÉO LÊN THEO PHƯƠNG X ====================
function TriggerEscape()
    if isEscaping then return end
    local myChar = player.Character
    if not myChar or not myChar:FindFirstChild("HumanoidRootPart") then return end
    local hrp = myChar.HumanoidRootPart
    local hum = myChar:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return end

    local target = selectedTarget
    if not target or not target.Character or not target.Character:FindFirstChild("HumanoidRootPart") then
        local closest = nil
        local closestDist = math.huge
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local dist = (p.Character.HumanoidRootPart.Position - hrp.Position).Magnitude
                if dist < closestDist then
                    closestDist = dist
                    closest = p
                end
            end
        end
        target = closest
    end

    if not target then return end
    local targetHrp = target.Character.HumanoidRootPart

    isEscaping = true
    local wasTelePro = IsTelePro
    IsTelePro = false

    -- Set network owner để có thể di chuyển mượt
    pcall(function()
        settings().Physics.AllowSleep = false
        for _, part in pairs(myChar:GetDescendants()) do
            if part:IsA("BasePart") and part:CanSetNetworkOwnership() then
                part:SetNetworkOwner(player)
            end
        end
    end)

    local escapeStart = tick()
    local escapeDuration = 2.0
    local zicZacSeed = math.random() * 100

    -- Lưu vị trí ban đầu
    local startPos = hrp.Position

    local escapeConnection
    escapeConnection = RunService.Heartbeat:Connect(function(deltaTime)
        if not hrp or not targetHrp or hum.Health <= 0 then
            if escapeConnection then escapeConnection:Disconnect() end
            isEscaping = false
            IsTelePro = wasTelePro
            return
        end

        local elapsed = tick() - escapeStart
        if elapsed >= escapeDuration then
            if escapeConnection then escapeConnection:Disconnect() end

            pcall(function()
                for _, part in pairs(myChar:GetDescendants()) do
                    if part:IsA("BasePart") and part:CanSetNetworkOwnership() then
                        part:SetNetworkOwner(nil)
                    end
                end
            end)

            hrp.AssemblyLinearVelocity = Vector3.zero
            hrp.AssemblyAngularVelocity = Vector3.zero
            isEscaping = false

            if wasTelePro then
                IsTelePro = true
                tpBtn.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
                tpBtn.Text = "ĐANG BÁM ⚡"
            end
            return
        end

        -- Tính toán vị trí đích: XÉO LÊN theo phương X
        -- Lấy vị trí hiện tại làm gốc, di chuyển theo X và Y
        local currentTargetX = startPos.X + Config.EscapeDistanceX
        local currentTargetY = startPos.Y + Config.EscapeHeight
        local currentTargetZ = startPos.Z

        -- Zic zac loạn xạ quanh vị trí đích
        local zicZacTime = elapsed * Config.EscapeZicZacSpeed
        
        -- Tạo dao động zic zac
        local zShakeX = math.sin(zicZacTime * 1.7 + zicZacSeed) * Config.EscapeZicZacIntensity * 0.3
        local zShakeY = math.cos(zicZacTime * 2.3 + zicZacSeed * 1.5) * Config.EscapeZicZacIntensity * 0.4
        local zShakeZ = math.sin(zicZacTime * 3.1 + zicZacSeed * 2.0) * Config.EscapeZicZacIntensity * 0.5

        -- Jitter ngẫu nhiên
        local jitterX = (math.noise(tick() * 22, zicZacSeed, 0) - 0.5) * Config.EscapeZicZacIntensity * 0.6
        local jitterY = (math.noise(0, tick() * 22, zicZacSeed) - 0.5) * Config.EscapeZicZacIntensity * 0.4
        local jitterZ = (math.noise(zicZacSeed, 0, tick() * 22) - 0.5) * Config.EscapeZicZacIntensity * 0.8

        -- Vị trí đích cuối cùng = vị trí cơ bản + zic zac + jitter
        local finalTargetPos = Vector3.new(
            currentTargetX + zShakeX + jitterX,
            currentTargetY + zShakeY + jitterY,
            currentTargetZ + zShakeZ + jitterZ
        )

        -- Hướng từ vị trí hiện tại đến vị trí đích
        local direction = (finalTargetPos - hrp.Position).Unit

        -- Tốc độ giảm dần khi gần đến đích
        local distToTarget = (finalTargetPos - hrp.Position).Magnitude
        local speedMultiplier = math.min(1, distToTarget / 50) -- Giảm tốc khi gần đích
        
        local currentSpeed = Config.EscapeSpeed * speedMultiplier

        -- Áp dụng vận tốc
        hrp.AssemblyLinearVelocity = direction * currentSpeed
        
        -- Xoay người loạn xạ theo zic zac
        hrp.AssemblyAngularVelocity = Vector3.new(
            (math.noise(tick() * 15, 0, 0) - 0.5) * Config.EscapeZicZacIntensity * 0.2,
            (math.noise(0, tick() * 15, 0) - 0.5) * Config.EscapeZicZacIntensity * 0.2,
            (math.noise(0, 0, tick() * 15) - 0.5) * Config.EscapeZicZacIntensity * 0.3
        )

        -- Giữ network owner
        pcall(function()
            for _, part in pairs(myChar:GetDescendants()) do
                if part:IsA("BasePart") and part:CanSetNetworkOwnership() then
                    part:SetNetworkOwner(player)
                end
            end
        end)
    end)
end

-- ==================== HỆ THỐNG PHÁT HIỆN MẤT MÁU ====================
local lastHealth = 100

local function CheckHealthChange()
    local char = player.Character
    if not char then return false end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if humanoid then
        if humanoid.Health < lastHealth then
            lastHealth = humanoid.Health
            return true
        end
        lastHealth = humanoid.Health
    end
    return false
end

player.CharacterAdded:Connect(function(char)
    local humanoid = char:WaitForChild("Humanoid")
    lastHealth = humanoid.Health
end)

