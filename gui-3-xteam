local function UpdatePlayerList()
    for _, child in ipairs(playerListContainer:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player then
            local pBtn = Instance.new("TextButton", playerListContainer)
            pBtn.Size = UDim2.new(1, -5, 0, 30)
            pBtn.Font = Enum.Font.Gotham
            pBtn.TextSize = 11
            pBtn.TextXAlignment = Enum.TextXAlignment.Left
            pBtn.ZIndex = 6
            Instance.new("UICorner", pBtn)

            if Config.HitboxWhitelist[p.Name] then
                pBtn.Text = "  [LOẠI TRỪ] " .. p.DisplayName .. " (@" .. p.Name .. ")"
                pBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
                pBtn.BackgroundColor3 = Color3.fromRGB(180, 40, 40)
            else
                pBtn.Text = "  " .. p.DisplayName .. " (@" .. p.Name .. ")"
                pBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
                pBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
            end

            pBtn.MouseButton1Click:Connect(function()
                if Config.HitboxWhitelist[p.Name] then
                    Config.HitboxWhitelist[p.Name] = nil
                    if p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                        p.Character.HumanoidRootPart.Size = Vector3.new(2, 2, 1)
                        p.Character.HumanoidRootPart.Transparency = 1
                        p.Character.HumanoidRootPart.Color = Color3.fromRGB(255, 255, 255)
                    end
                else
                    Config.HitboxWhitelist[p.Name] = true
                end
                selectedTarget = p
                nameBox.Text = p.Name
                UpdatePlayerList()
            end)
        end
    end
    playerListContainer.CanvasSize = UDim2.new(0, 0, 0, playerListLayout.AbsoluteContentSize.Y + 5)
end

Players.PlayerAdded:Connect(UpdatePlayerList)
Players.PlayerRemoving:Connect(function(p)
    Config.HitboxWhitelist[p.Name] = nil
    UpdatePlayerList()
end)
