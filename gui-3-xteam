-- Hàm tạo thanh điều chỉnh
local function CreateSlider(parent, label, default, callback, step)
    local frame = Instance.new("Frame", parent)
    frame.Size = UDim2.new(1, 0, 0, 50)
    frame.BackgroundTransparency = 1
    frame.ZIndex = 6

    local lbl = Instance.new("TextLabel", frame)
    lbl.Size = UDim2.new(1, 0, 0, 15)
    lbl.Text = label
    lbl.TextColor3 = Color3.fromRGB(200, 200, 200)
    lbl.BackgroundTransparency = 1
    lbl.Font = Enum.Font.Gotham
    lbl.TextSize = 10
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.ZIndex = 6

    local box = Instance.new("TextBox", frame)
    box.Size = UDim2.new(0.3, 0, 0, 25)
    box.Position = UDim2.new(0, 0, 0, 18)
    box.Text = tostring(default)
    box.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    box.TextColor3 = Color3.fromRGB(255, 255, 255)
    box.Font = Enum.Font.GothamBold
    box.TextSize = 12
    box.ZIndex = 6
    Instance.new("UICorner", box)

    local minus = Instance.new("TextButton", frame)
    minus.Size = UDim2.new(0.25, 0, 0, 25)
    minus.Position = UDim2.new(0.35, 0, 0, 18)
    minus.Text = "-"
    minus.BackgroundColor3 = Color3.fromRGB(150, 40, 40)
    minus.TextColor3 = Color3.fromRGB(255, 255, 255)
    minus.Font = Enum.Font.GothamBlack
    minus.TextSize = 16
    minus.ZIndex = 6
    Instance.new("UICorner", minus)

    local plus = Instance.new("TextButton", frame)
    plus.Size = UDim2.new(0.25, 0, 0, 25)
    plus.Position = UDim2.new(0.75, 0, 0, 18)
    plus.Text = "+"
    plus.BackgroundColor3 = Color3.fromRGB(40, 150, 40)
    plus.TextColor3 = Color3.fromRGB(255, 255, 255)
    plus.Font = Enum.Font.GothamBlack
    plus.TextSize = 16
    plus.ZIndex = 6
    Instance.new("UICorner", plus)

    step = step or 2

    box:GetPropertyChangedSignal("Text"):Connect(function()
        local n = tonumber(box.Text)
        if n then callback(n) end
    end)

    minus.MouseButton1Click:Connect(function()
        local curr = tonumber(box.Text) or default
        curr = math.max(0, curr - step)
        box.Text = tostring(curr)
        callback(curr)
    end)

    plus.MouseButton1Click:Connect(function()
        local curr = tonumber(box.Text) or default
        curr = curr + step
        box.Text = tostring(curr)
        callback(curr)
    end)

    return frame
end

