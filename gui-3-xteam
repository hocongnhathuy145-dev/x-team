RunService.Stepped:Connect(function(time, deltaTime)
    local c = player.Character
    if not c or not c:FindFirstChild("HumanoidRootPart") then return end
    local hrp = c.HumanoidRootPart

    if IsNoclip or IsTelePro or AutoFarmActive or isEscaping or Config.IsHitboxExtend then
        for _, v in pairs(c:GetDescendants()) do
            if v:IsA("BasePart") then
                v.CanCollide = false
            end
        end
    end

    local t = selectedTarget
    local s = nameBox.Text:lower()
    if s ~= "" and s ~= "nhập tên mục tiêu..." and s ~= "nhập tên..." then
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= player and (p.Name:lower():find(s) or p.DisplayName:lower():find(s)) then
                t = p
                selectedTarget = p
                break
            end
        end
    end

    local currentOX, currentOY, currentOZ = Config.OX, Config.OY, Config.OZ

    if isZicZac and t and t.Character and t.Character:FindFirstChild("HumanoidRootPart") and not isEscaping then
        circleAngle = circleAngle + (Config.ZZSpeed * deltaTime)
        upDownCounter = upDownCounter + (Config.ZZUpDownSpeed * deltaTime)

        currentOX = math.sin(circleAngle) * Config.ZZRange
        currentOZ = math.cos(circleAngle) * Config.ZZRange
        currentOY = Config.OY + math.sin(upDownCounter) * (Config.ZZRange * 0.5)

        local jitterX = (math.noise(tick() * 22, 0, 0) * Config.LightningJitter)
        local jitterZ = (math.noise(0, tick() * 22, 0) * Config.LightningJitter)
        local jitterY = (math.noise(0, 0, tick() * 28) * (Config.LightningJitter * 0.7))

        currentOX = currentOX + jitterX
        currentOZ = currentOZ + jitterZ
        currentOY = currentOY + jitterY
    end

    if IsTelePro and not IsBringLoop and t and t.Character and t.Character:FindFirstChild("HumanoidRootPart") and not isEscaping then
        local thrp = t.Character.HumanoidRootPart
        local cleanTargetCFrame = CFrame.new(thrp.Position) * (thrp.CFrame - thrp.Position)
        local tp = cleanTargetCFrame * CFrame.new(currentOX, currentOY, currentOZ)

        local dist = (tp.Position - hrp.Position).Magnitude
        if dist > 20 then
            hrp.Velocity = (tp.Position - hrp.Position).Unit * 200
        else
            hrp.CFrame = tp
            hrp.Velocity = Vector3.zero
        end
    end
end)

RunService.RenderStepped:Connect(function()
    if not Config.IsHitboxExtend then return end
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character then
            local root = p.Character:FindFirstChild("HumanoidRootPart")
            if root then
                if Config.HitboxWhitelist[p.Name] then
                    root.Size = Vector3.new(2, 2, 1)
                    root.Transparency = 1
                else
                    root.Size = Vector3.new(Config.HitboxSize, Config.HitboxSize, Config.HitboxSize)
                    root.Transparency = 0.5
                    root.Color = Color3.fromRGB(0, 255, 0)
                    root.CanCollide = false
                end
            end
        end
    end
end)

