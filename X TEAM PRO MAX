        local hrp = myChar.HumanoidRootPart

        if Config.IsAutoEscape and CheckHitboxAndBlock() and not isEscaping then
            isEscaping = true
            escapeTimer = Config.EscapeDuration 
            
            local currentY = hrp.Position.Y
            targetEscapeY = (currentY >= 500) and (currentY + 500) or Config.DefaultEscapeHeight
            
            hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
            hrp.CFrame = CFrame.new(hrp.Position.X, targetEscapeY, hrp.Position.Z)
        end

        if isEscaping then
            escapeTimer = escapeTimer - deltaTime
            if escapeTimer > 0 then
                angle = angle + (Config.CircleSpeed * deltaTime)
                local offsetX = math.cos(angle) * Config.CircleRadius
                local offsetZ = math.sin(angle) * Config.CircleRadius
                hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                hrp.CFrame = CFrame.new(hrp.Position.X + offsetX, targetEscapeY, hrp.Position.Z + offsetZ)
            else
                isEscaping = false 
            end
        end
    end)

