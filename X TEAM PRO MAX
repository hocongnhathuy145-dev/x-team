    local function CheckHitboxAndBlock()
        local char = player.Character
        if not char then return false end
        
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        if humanoid then
            if humanoid.Health < lastHealth then
                lastHealth = humanoid.Health
                return true
            end
            lastHealth = humanoid.Health
        end
        
        if char:GetAttribute("Stunned") or char:GetAttribute("GuardBroken") or char:GetAttribute("Ragdoll") then
            return true
        end
        if char:FindFirstChild("Stun") or char:FindFirstChild("GuardBreak") then
            return true
        end
        
        return false
    end

