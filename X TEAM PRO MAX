        -- Logic ZicZac phụ trợ (Giữ lại từ bản cũ nếu bật ZZ)
        local currentOX, currentOY, currentOZ = Config.OX, Config.OY, Config.OZ
        if isZicZac and t and t.Character and t.Character:FindFirstChild("HumanoidRootPart") then
            zzAngle = zzAngle + (Config.ZZSpeed * 0.01)
            local zigZagSine = math.sin(zzAngle * 5) * (Config.ZZRange * 0.4)
            local currentRadius = Config.ZZRange + zigZagSine
            currentOX = math.cos(zzAngle) * currentRadius
            currentOZ = math.sin(zzAngle) * currentRadius
        end
        
        if IsTelePro and not IsBringLoop and t and t.Character and t.Character:FindFirstChild("HumanoidRootPart") and not isEscaping then
            local thrp = t.Character.HumanoidRootPart
            local tp = thrp.CFrame * CFrame.new(currentOX, currentOY, currentOZ)
            local dir = tp.Position - hrp.Position
            local dist = dir.Magnitude
            if dist > 20 then
                hrp.Velocity = dir.Unit * 200
            else
                hrp.CFrame = tp
                hrp.Velocity = Vector3.zero
            end
        end
        
        if IsNoclip or IsTelePro or AutoFarmActive or isEscaping then
            for _, v in pairs(c:GetDescendants()) do
                if v:IsA("BasePart") then
                    v.CanCollide = false
                end
            end
        end
    end)

