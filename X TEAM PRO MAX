    removeWlBtn.Size = UDim2.new(0.46,0,0,40); removeWlBtn.Position = UDim2.new(0.54,-5,0,240); removeWlBtn.Text = "XÓA KHỎI WL"; removeWlBtn.BackgroundColor3 = Color3.fromRGB(100,0,0); removeWlBtn.TextColor3 = Color3.fromRGB(255,255,255); removeWlBtn.Font = Enum.Font.GothamBold; Instance.new("UICorner", removeWlBtn)

    local wlStatusLabel = Instance.new("TextLabel", sec2)
    wlStatusLabel.Size = UDim2.new(1,-10,0,40); wlStatusLabel.Position = UDim2.new(0,5,0,290); wlStatusLabel.Text = "Chưa có ai trong danh sách Whitelist."; wlStatusLabel.TextColor3 = Color3.fromRGB(150,150,150); wlStatusLabel.BackgroundTransparency = 1; wlStatusLabel.TextWrapped = true; wlStatusLabel.TextSize = 11

    hitboxSizeBox:GetPropertyChangedSignal("Text"):Connect(function() Config.HitboxSize = tonumber(hitboxSizeBox.Text) or 15 end)

    local function UpdateWlStatus()
        local list = {}
        for name, _ in pairs(Config.Whitelist) do table.insert(list, name) end
        wlStatusLabel.Text = (#list == 0) and "Chưa có ai trong danh sách Whitelist." or "Đang loại trừ: " .. table.concat(list, ", ")
    end

    -- ==================== KẾT NỐI TƯƠNG TÁC BUTTONS ====================
    tpBtn.MouseButton1Click:Connect(function()
        local textName = nameBox.Text
        if textName == "" then return end
        IsTelePro = not IsTelePro -- Thay đổi trạng thái dí mục tiêu theo biến mới của bạn
        
        if IsTelePro then
            tpBtn.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
            tpBtn.Text = "ĐANG DÍ: " .. textName:upper()
        else
            tpBtn.BackgroundColor3 = Color3.fromRGB(60,60,60) 
            tpBtn.Text = "TELEPORT LƠ LỬNG" 
            local c = player.Character
            if c and c:FindFirstChild("HumanoidRootPart") then
                c.HumanoidRootPart.Velocity = Vector3.zero
            end
        end
    end)

    zzBtn.MouseButton1Click:Connect(function()
        local textName = nameBox.Text
        if textName == "" then return end
        isZicZac = not isZicZac

        if isZicZac then
            zzBtn.BackgroundColor3 = Color3.fromRGB(230, 130, 0) 
            zzBtn.Text = "ZZ ĐANG BẬT"
        else
            zzBtn.BackgroundColor3 = Color3.fromRGB(60,60,60) 
            zzBtn.Text = "BẬT CHẾ ĐỘ ZIC ZAC"
        end
    end)

    escapeBtn.MouseButton1Click:Connect(function()
        Config.IsAutoEscape = not Config.IsAutoEscape
        escapeBtn.BackgroundColor3 = Config.IsAutoEscape and Color3.fromRGB(0, 170, 0) or Color3.fromRGB(60,60,60)
        escapeBtn.Text = Config.IsAutoEscape and "ĐANG BẬT ESCAPE XOAY VÒNG" or "BẬT AUTO ESCAPE XOAY VÒNG"
    end)

    m1m2Btn.MouseButton1Click:Connect(function()
        Config.IsAutoClick = not Config.IsAutoClick
        m1m2Btn.BackgroundColor3 = Config.IsAutoClick and Color3.fromRGB(0, 170, 0) or Color3.fromRGB(60,60,60)
    end)

    blockBtn.MouseButton1Click:Connect(function()
        Config.IsAutoReblock = not Config.IsAutoReblock
        blockBtn.BackgroundColor3 = Config.IsAutoReblock and Color3.fromRGB(0, 170, 0) or Color3.fromRGB(60,60,60)
    end)

    hitboxToggleBtn.MouseButton1Click:Connect(function()
        Config.IsHitboxExtend = not Config.IsHitboxExtend
        hitboxToggleBtn.BackgroundColor3 = Config.IsHitboxExtend and Color3.fromRGB(0, 170, 0) or Color3.fromRGB(60,60,60)
        hitboxToggleBtn.Text = Config.IsHitboxExtend and "ĐANG BẬT KÉO TÂM HITBOX" or "BẬT KÉO TÂM HITBOX"
        if not Config.IsHitboxExtend then
            for _, p in ipairs(Players:GetPlayers()) do
                if p.Character then
                    local root = p.Character:FindFirstChild("HumanoidRootPart")
                    if root then root.Size = Vector3.new(2, 2, 1) root.Transparency = 1 end
                end
            end
        end
    end)

    addWlBtn.MouseButton1Click:Connect(function()
        local textName = whitelistBox.Text if textName == "" then return end
        -- Tìm kiếm nhanh mục tiêu để đưa vào whitelist bảo vệ
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player and (p.Name:lower():find(textName:lower()) or p.DisplayName:lower():find(textName:lower())) then
                Config.Whitelist[p.Name] = true
                UpdateWlStatus()
                whitelistBox.Text = ""
                break
            end
        end
    end)

    removeWlBtn.MouseButton1Click:Connect(function()
        local textName = whitelistBox.Text if textName == "" then return end
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player and (p.Name:lower():find(textName:lower()) or p.DisplayName:lower():find(textName:lower())) then
                if Config.Whitelist[p.Name] then
                    Config.Whitelist[p.Name] = nil
                    if p.Character then
                        local root = p.Character:FindFirstChild("HumanoidRootPart")
                        if root then root.Size = Vector3.new(2, 2, 1) root.Transparency = 1 end
                    end
                    UpdateWlStatus()
                    whitelistBox.Text = ""
                    break
                end
            end
        end
    end)

    Toggle.MouseButton1Click:Connect(function() Main.Visible = not Main.Visible end)
end

