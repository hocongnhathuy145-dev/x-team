    <script>
        // Hàm xử lý đăng nhập
        function handleLogin() {
            const username = document.getElementById('zaidepnung02').value;
            const password = document.getElementById('nhathuy1405').value;
            
            if (!username || !password) {
                alert('⚠️ Vui lòng nhập đầy đủ thông tin đăng nhập!');
                return;
            }
            
            // Giả lập kiểm tra đăng nhập
            if (username === 'zaidepnung02' && password === 'nhathuy1405') {
