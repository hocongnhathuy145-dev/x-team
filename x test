            <button class="btn-signin" onclick="handleLogin()">Đăng nhập</button>
            
            <div class="passkey-info">
                <a href="#">🔑 Đăng nhập bằng passkey</a>
            </div>
            
            <div class="create-account">
                Người mới? <a href="#">Tạo tài khoản</a>
            </div>
        </div>

        <!-- Footer Links -->
        <div class="footer-links">
            <a href="#">Điều khoản</a>
            <a href="#">Bảo mật</a>
            <a href="#">Liên hệ</a>
            <a href="#"><i class="fa-brands fa-github"></i> GitHub Repository</a>
