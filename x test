                // Chuyển hướng đến game (tuỳ chỉnh)
                // window.location.href = 'game.html';
            } else {
                alert('❌ Sai tên đăng nhập hoặc mật khẩu!\n\nGợi ý: BẠN KHÔNG CÓ QUYỀN DỤNG SCRIPT');
            }
        }
        
        // Cho phép nhấn Enter để đăng nhập
        document.addEventListener('keypress', function(e) {
