<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Homeless Life - Sign in to GitHub</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --bg-primary: #0d1117;
            --bg-secondary: #161b22;
            --bg-tertiary: #21262d;
            --border-color: #30363d;
            --text-primary: #c9d1d9;
            --text-secondary: #8b949e;
            --text-link: #58a6ff;
            --accent-orange: #f0883e;
            --accent-green: #3fb950;
            --accent-red: #f85149;
            --btn-primary-bg: #238636;
            --btn-primary-hover: #2ea043;
            --input-bg: #0d1117;
            --input-focus: #1f6feb;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Noto Sans', Helvetica, Arial, sans-serif;
            background-color: var(--bg-primary);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        /* GitHub Header */
        .github-header {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            background: #24292f;
            padding: 16px 32px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            z-index: 10;
            border-bottom: 1px solid var(--border-color);
        }

        .github-logo {
            color: #ffffff;
            font-size: 32px;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .github-logo i {
            font-size: 32px;
        }

        .github-logo span {
            font-size: 14px;
            color: var(--text-secondary);
            font-weight: 400;
        }

        .header-actions {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .header-link {
            color: #ffffff;
            text-decoration: none;
            font-size: 14px;
            transition: opacity 0.15s ease;
        }

        .header-link:hover {
            opacity: 0.7;
        }

        /* Main Container */
        .main-container {
            margin-top: 60px;
            width: 100%;
            max-width: 440px;
        }

        /* Logo */
        .logo-section {
            text-align: center;
            margin-bottom: 16px;
        }

        .github-mark {
            width: 48px;
            height: 48px;
            margin: 0 auto 16px;
            display: block;
            color: #ffffff;
            font-size: 48px;
        }

        .logo-section h1 {
            font-size: 24px;
            font-weight: 300;
            color: var(--text-primary);
            letter-spacing: -0.5px;
            margin-bottom: 8px;
        }

        /* Login Card */
        .login-card {
            background: var(--bg-secondary);
            border: 1px solid var(--border-color);
            border-radius: 6px;
            padding: 20px;
        }

        .login-card label {
            display: block;
            font-size: 14px;
            font-weight: 400;
            color: var(--text-primary);
            margin-bottom: 8px;
        }

        .login-card .label-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .login-card .label-row a {
            font-size: 12px;
            color: var(--text-link);
            text-decoration: none;
        }

        .login-card .label-row a:hover {
            text-decoration: underline;
        }

        .form-input {
            width: 100%;
            padding: 5px 12px;
            background: var(--input-bg);
            border: 1px solid var(--border-color);
            border-radius: 6px;
            color: var(--text-primary);
            font-size: 14px;
            font-family: inherit;
            line-height: 20px;
            margin-bottom: 16px;
            outline: none;
            transition: all 0.15s ease;
        }

        .form-input:focus {
            border-color: var(--input-focus);
            box-shadow: 0 0 0 3px rgba(31, 111, 235, 0.15);
        }

        .btn-signin {
            width: 100%;
            padding: 5px 16px;
            background: var(--btn-primary-bg);
            color: #ffffff;
            border: 1px solid rgba(240, 246, 252, 0.1);
            border-radius: 6px;
            font-size: 14px;
            font-weight: 500;
            font-family: inherit;
            cursor: pointer;
            transition: background 0.15s ease;
            margin-bottom: 16px;
        }

        .btn-signin:hover {
            background: var(--btn-primary-hover);
        }

        .login-card .passkey-info {
            padding: 16px;
            background: var(--bg-primary);
            border: 1px solid var(--border-color);
            border-radius: 6px;
            text-align: center;
            margin-bottom: 16px;
        }

        .login-card .passkey-info a {
            color: var(--text-link);
            text-decoration: none;
            font-size: 14px;
        }

        .login-card .passkey-info a:hover {
            text-decoration: underline;
        }

        .create-account {
            text-align: center;
            padding: 16px;
            border: 1px solid var(--border-color);
            border-radius: 6px;
            font-size: 14px;
            color: var(--text-primary);
        }

        .create-account a {
            color: var(--text-link);
            text-decoration: none;
        }

        .create-account a:hover {
            text-decoration: underline;
        }

        /* Footer */
        .footer-links {
            text-align: center;
            margin-top: 40px;
            padding: 20px;
            font-size: 12px;
            color: var(--text-secondary);
        }

        .footer-links a {
            color: var(--text-secondary);
            text-decoration: none;
            margin: 0 8px;
        }

        .footer-links a:hover {
            color: var(--text-link);
            text-decoration: underline;
        }

        .footer-links i {
            color: #6e7681;
        }

        /* Responsive */
        @media (max-width: 480px) {
            .github-header {
                padding: 12px 16px;
            }
            
            .login-card {
                padding: 16px;
            }
            
            .logo-section h1 {
                font-size: 20px;
            }
            
            .footer-links {
                margin-top: 24px;
            }
        }
    </style>
</head>
<body>

    <!-- GitHub Header -->
    <header class="github-header">
        <a href="https://github.com" class="github-logo">
            <i class="fa-brands fa-github"></i>
            <span>Homeless Life Game</span>
        </a>
        <div class="header-actions">
            <a href="#" class="header-link">Tài liệu</a>
            <a href="#" class="header-link">Hỗ trợ</a>
        </div>
