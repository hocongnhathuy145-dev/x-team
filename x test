<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Homeless Life - Bay đến người chơi</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    
    <style>
        :root {
            --bg-primary: #0d1117;
            --bg-secondary: #161b22;
            --bg-tertiary: #21262d;
            --border: #30363d;
            --text: #c9d1d9;
            --text-secondary: #8b949e;
            --accent-blue: #58a6ff;
            --accent-green: #3fb950;
            --accent-orange: #f0883e;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
            background: var(--bg-primary);
            color: var(--text);
            min-height: 100vh;
            overflow: hidden;
        }

        /* HEADER */
        .header {
            background: var(--bg-secondary);
            border-bottom: 1px solid var(--border);
            padding: 10px 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .game-logo {
            width: 36px; height: 36px;
            background: linear-gradient(135deg, #f0883e, #c24e1f);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
        }

        .server-info span {
            font-size: 13px;
            color: var(--accent-green);
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .live-dot {
            width: 8px; height: 8px;
            background: var(--accent-green);
            border-radius: 50%;
            animation: pulse 1.5s infinite;
        }

        @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.4; } }

        /* MAIN */
        .main {
            display: grid;
            grid-template-columns: 1fr 400px;
            height: calc(100vh - 57px);
        }

        /* MAP */
        .map-container {
            position: relative;
            background: var(--bg-primary);
            overflow: hidden;
        }

        .map-grid {
            position: absolute;
            inset: 0;
            background-image: 
                linear-gradient(rgba(48,54,61,0.3) 1px, transparent 1px),
                linear-gradient(90deg, rgba(48,54,61,0.3) 1px, transparent 1px);
            background-size: 50px 50px;
            pointer-events: none;
        }

        .obstacle {
            position: absolute;
            background: rgba(48,54,61,0.6);
            border: 1px solid var(--border);
            border-radius: 4px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 26px;
            opacity: 0.7;
            pointer-events: none;
        }

        .player-marker {
            position: absolute;
            transform: translate(-50%, -50%);
            z-index: 10;
            cursor: pointer;
            transition: left 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                        top 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }

        .marker-dot {
            width: 36px; height: 36px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 17px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.6);
            border: 2px solid rgba(255,255,255,0.3);
            position: relative;
        }

        .marker-pulse {
            position: absolute;
            inset: 0;
            border: 2px solid currentColor;
            border-radius: 50%;
            animation: markerPulse 2s infinite;
        }

        @keyframes markerPulse {
            to { transform: scale(3.5); opacity: 0; }
        }

        /* My Player */
        #myPlayer {
            position: absolute;
            transform: translate(-50%, -50%);
            z-index: 20;
            transition: all 1.1s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        .my-icon {
            width: 48px; height: 48px;
            background: linear-gradient(135deg, #58a6ff, #1f6feb);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 26px;
            border: 3px solid white;
            box-shadow: 0 0 40px rgba(88,166,255,0.7);
            animation: glow 1.6s infinite alternate;
        }

        @keyframes glow {
            from { box-shadow: 0 0 30px rgba(88,166,255,0.6); }
            to   { box-shadow: 0 0 55px rgba(88,166,255,0.9); }
        }

        /* PLAYER PANEL */
        .panel {
            background: var(--bg-secondary);
            border-left: 1px solid var(--border);
            display: flex;
            flex-direction: column;
        }

        .panel-header {
            padding: 16px;
            border-bottom: 1px solid var(--border);
        }

        .fly-input-group {
            display: flex;
            gap: 8px;
        }

        .fly-input {
            flex: 1;
            padding: 10px 12px;
            background: var(--bg-primary);
            border: 1px solid var(--border);
            border-radius: 6px;
            color: var(--text);
            font-size: 14px;
        }

        .fly-input:focus {
            border-color: var(--accent-blue);
            box-shadow: 0 0 0 3px rgba(88,166,255,0.15);
        }

        .btn-fly {
            padding: 10px 18px;
            background: var(--accent-blue);
            color: white;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-weight: 500;
            transition: 0.2s;
        }

        .btn-fly:hover { background: #4090e0; }
        .btn-fly:disabled { opacity: 0.6; cursor: not-allowed; }

        .player-list {
            flex: 1;
            overflow-y: auto;
            padding: 8px;
        }

        .player-card {
            background: var(--bg-primary);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 12px;
            margin-bottom: 8px;
            display: flex;
            align-items: center;
            gap: 12px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .player-card:hover {
            border-color: var(--accent-orange);
            transform: translateX(4px);
        }

        .player-card.fly-highlight {
            animation: highlight 600ms ease;
            border-color: var(--accent-blue) !important;
        }

        @keyframes highlight {
            0%,100% { transform: scale(1); }
            50% { transform: scale(1.04); }
        }

        /* Notification */
        .notification {
            position: fixed;
            top: 20px;
            right: 20px;
            background: var(--bg-secondary);
            border: 1px solid var(--accent-blue);
            border-radius: 8px;
            padding: 14px 18px;
            display: flex;
            gap: 12px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            animation: slideIn 0.3s, slideOut 0.3s 2.2s forwards;
            z-index: 1000;
        }

        @keyframes slideIn { from { transform: translateX(120%); } }
        @keyframes slideOut { to { transform: translateX(120%); opacity: 0; } }

        /* Responsive */
        @media (max-width: 768px) {
            .main { grid-template-columns: 1fr; grid-template-rows: 1fr 420px; }
            .panel { border-left: none; border-top: 1px solid var(--border); }
        }
    </style>
</head>
<body>

    <!-- HEADER -->
    <header class="header">
        <div class="logo">
            <div class="game-logo">🏚️</div>
            <div>
                <h2 style="font-size:16px">Homeless Life</h2>
                <span><span class="live-dot"></span> Server Online</span>
            </div>
        </div>
        <div style="display:flex; align-items:center; gap:12px;">
            <div class="player-count-badge">
                <i class="fa-solid fa-users"></i>
                <span id="playerCount">0</span> người chơi
            </div>
            <button class="btn-refresh" onclick="refreshPlayers()">
                <i class="fa-solid fa-rotate"></i> Làm mới
            </button>
        </div>
    </header>

    <div class="main">
        <!-- MAP -->
        <div class="map-container" id="mapContainer">
            <div class="map-grid"></div>
            <div class="my-player" id="myPlayer" style="left:50%; top:50%;">
                <div class="my-icon">🧑</div>
                <div style="position:absolute; top:100%; left:50%; transform:translateX(-50%); margin-top:6px; background:var(--bg-secondary); padding:2px 10px; border-radius:12px; font-size:12px; white-space:nowrap;">
                    Bạn
                </div>
            </div>
        </div>

        <!-- PLAYER PANEL -->
        <div class="panel">
            <div class="panel-header">
                <h3><i class="fa-solid fa-magnifying-glass"></i> Bay đến người chơi</h3>
                <div class="fly-input-group">
                    <input type="text" id="flyInput" class="fly-input" placeholder="Nhập tên người chơi..." autocomplete="off">
                    <button class="btn-fly" id="btnFly" onclick="flyToPlayer()">
                        <i class="fa-solid fa-rocket"></i> Bay
                    </button>
                </div>
                <div class="search-suggestions" id="suggestions"></div>
            </div>
            <div class="player-list" id="playerList"></div>
        </div>
    </div>

    <div id="notificationContainer"></div>

    <script>
        // Cache DOM
        const DOM = {
            map: document.getElementById('mapContainer'),
            myPlayer: document.getElementById('myPlayer'),
            playerList: document.getElementById('playerList'),
            flyInput: document.getElementById('flyInput'),
            suggestions: document.getElementById('suggestions'),
            btnFly: document.getElementById('btnFly'),
            playerCount: document.getElementById('playerCount')
        };

        let players = [];
        let myPosition = { x: 50, y: 50 };

        const locations = ['Công viên trung tâm','Ga tàu điện ngầm','Cầu vượt số 3','Bến xe buýt','Khu phố cổ','Trung tâm thương mại','Bãi đỗ xe ngầm','Công trường bỏ hoang','Bờ sông','Khu ổ chuột'];
        const colors = ['#f0883e','#3fb950','#a371f7','#58a6ff','#d2991d','#f85149'];
        const avatars = ['🧔','👩','👨','🧑','👴','👵','🧒','👦','👧'];

        function init() {
            generateObstacles();
            generatePlayers();
            renderAll();
            setupListeners();
            
            setInterval(updatePositions, 2800);
            setInterval(addRandomPlayer, 7500);
            setInterval(removeRandomPlayer, 11000);
        }

        function generateObstacles() {
            const obs = [
                {e:'🏠',x:15,y:25,w:80,h:60},{e:'🏢',x:40,y:15,w:70,h:90},
                {e:'🌳',x:25,y:60,w:40,h:40},{e:'🏗️',x:60,y:65,w:75,h:50}
            ];
            obs.forEach(o => {
                const el = document.createElement('div');
                el.className = 'obstacle';
                el.style.cssText = `left:\( {o.x}%;top: \){o.y}%;width:\( {o.w}px;height: \){o.h}px;`;
                el.textContent = o.e;
                DOM.map.appendChild(el);
            });
        }

        function generatePlayers() {
            const names = ['ShadowWalker','NightHawk','StreetKing','UrbanFox','CityWolf','DarkRider','AlleyCat','BridgeTroll'];
            players = names.map((name,i) => ({
                id: i+1,
                name,
                avatar: avatars[i % avatars.length],
                color: colors[i % colors.length],
                level: Math.floor(Math.random()*45)+5,
                location: locations[i % locations.length],
                x: Math.random()*75 + 12,
                y: Math.random()*75 + 12,
                online: true
            }));
        }

        function renderAll() {
            renderMapMarkers();
            renderPlayerList();
            updatePlayerCount();
        }

        function renderMapMarkers() {
            // Xóa marker cũ
            document.querySelectorAll('.player-marker').forEach(el => el.remove());

            players.forEach(p => {
                if (!p.online) return;
                const marker = document.createElement('div');
                marker.className = 'player-marker';
                marker.style.left = p.x + '%';
                marker.style.top = p.y + '%';
                marker.innerHTML = `
                    <div class="marker-dot" style="background:${p.color}">
                        ${p.avatar}
                        <div class="marker-pulse"></div>
                    </div>
                    <div class="marker-tooltip" style="position:absolute;bottom:calc(100%+8px);left:50%;transform:translateX(-50%);background:var(--bg-secondary);padding:6px 12px;border-radius:6px;font-size:12px;white-space:nowrap;border:1px solid var(--border);">
                        <strong>\( {p.name}</strong> · Lv. \){p.level}<br>📍 ${p.location}
                    </div>
                `;
                marker.onclick = () => flyToPlayerById(p.id);
                DOM.map.appendChild(marker);
            });
        }

        function renderPlayerList(filter = '') {
            const term = filter.toLowerCase();
            const filtered = players
                .filter(p => p.name.toLowerCase().includes(term) || p.location.toLowerCase().includes(term))
                .sort((a,b) => (b.online - a.online) || a.name.localeCompare(b.name));

            DOM.playerList.innerHTML = filtered.map(p => `
                <div class="player-card" data-id="${p.id}">
                    <div class="player-avatar" style="background:${p.color}25; width:42px;height:42px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:20px;position:relative;">
                        ${p.avatar}
                        ${p.online ? '<div style="position:absolute;bottom:-2px;right:-2px;width:12px;height:12px;background:#3fb950;border:2px solid var(--bg-primary);border-radius:50%;"></div>' : ''}
                    </div>
                    <div style="flex:1">
                        <div style="display:flex;align-items:center;gap:6px">
                            <span style="font-weight:600">${p.name}</span>
                            <span style="font-size:10px;background:#a371f7;color:white;padding:1px 6px;border-radius:10px">Lv.${p.level}</span>
                        </div>
                        <div style="font-size:12px;color:var(--text-secondary);margin-top:2px">
                            📍 ${p.location}
                        </div>
                    </div>
                    \( {p.online ? `<button class="btn-fly-small" style="padding:6px 12px;font-size:12px" onclick="event.stopImmediatePropagation();flyToPlayerById( \){p.id})">Bay</button>` : ''}
                </div>
            `).join('');

            // Event cho card
            filtered.forEach(p => {
                const card = DOM.playerList.querySelector(`[data-id="${p.id}"]`);
                if (card && p.online) card.addEventListener('click', () => flyToPlayerById(p.id));
            });
        }

        function updatePlayerCount() {
            DOM.playerCount.textContent = players.filter(p => p.online).length;
        }

        function updatePositions() {
            players.forEach(p => {
                if (p.online) {
                    p.x = Math.max(8, Math.min(92, p.x + (Math.random()-0.5)*7));
                    p.y = Math.max(8, Math.min(92, p.y + (Math.random()-0.5)*7));
                }
            });
            renderMapMarkers();
            renderPlayerList(DOM.flyInput.value);
        }

        // Bay đến người chơi
        function flyToPlayerById(id) {
            const player = players.find(p => p.id === id);
            if (!player || !player.online) return;
            executeFly(player);
        }

        function flyToPlayer() {
            const name = DOM.flyInput.value.trim();
            if (!name) return showNotification('warning', 'Vui lòng nhập tên!');
            
            const player = players.find(p => p.name.toLowerCase() === name.toLowerCase() && p.online);
            if (!player) return showNotification('error', `Không tìm thấy "${name}"!`);
            
            executeFly(player);
        }

        function executeFly(target) {
            DOM.btnFly.disabled = true;
            DOM.btnFly.innerHTML = `<i class="fa-solid fa-spinner fa-spin"></i> Đang bay...`;

            // Highlight
            const card = DOM.playerList.querySelector(`[data-id="${target.id}"]`);
            if (card) {
                card.classList.add('fly-highlight');
                setTimeout(() => card.classList.remove('fly-highlight'), 700);
            }

            createTrail(target);
            
            DOM.myPlayer.style.left = target.x + '%';
            DOM.myPlayer.style.top = target.y + '%';
            
            myPosition = { x: target.x, y: target.y };

            showNotification('success', `🚀 Đã bay đến ${target.name}!`, target.location);

            setTimeout(() => {
                DOM.btnFly.disabled = false;
                DOM.btnFly.innerHTML = `<i class="fa-solid fa-rocket"></i> Bay`;
                renderPlayerList(DOM.flyInput.value);
            }, 1300);
        }

        function createTrail(target) {
            const steps = 18;
            for (let i = 0; i < steps; i++) {
                setTimeout(() => {
                    const progress = i / steps;
                    const ease = 1 - Math.pow(1 - progress, 3);
                    const x = myPosition.x + (target.x - myPosition.x) * ease;
                    const y = myPosition.y + (target.y - myPosition.y) * ease;

                    const p = document.createElement('div');
                    p.style.cssText = `
                        position:absolute; left:\( {x}%; top: \){y}%; 
                        width:\( {5+Math.random()*7}px; height: \){5+Math.random()*7}px;
                        background:${target.color}; border-radius:50%;
                        pointer-events:none; z-index:15;
                        animation: trailFade 0.7s forwards;
                    `;
                    DOM.map.appendChild(p);
                    setTimeout(() => p.remove(), 800);
                }, i * 35);
            }
        }

        function setupListeners() {
            // Search
            DOM.flyInput.addEventListener('input', () => {
                renderPlayerList(DOM.flyInput.value);
            });

            DOM.flyInput.addEventListener('keypress', e => {
                if (e.key === 'Enter') flyToPlayer();
            });
        }

        function showNotification(type, message, detail = '') {
            const noti = document.createElement('div');
            noti.className = 'notification';
            noti.innerHTML = `
                <i class="fa-solid \( {type==='success'?'fa-circle-check':type==='error'?'fa-circle-xmark':'fa-circle-info'}" style="color: \){type==='success'?'#3fb950':type==='error'?'#f85149':'#58a6ff'}"></i>
                <div>
                    <div style="font-weight:600">${message}</div>
                    \( {detail ? `<div style="font-size:12px;color:var(--text-secondary)"> \){detail}</div>` : ''}
                </div>
            `;
            document.getElementById('notificationContainer').appendChild(noti);
            setTimeout(() => noti.remove(), 2600);
        }

        function addRandomPlayer() { /* ... */ }
        function removeRandomPlayer() { /* ... */ }
        function refreshPlayers() { /* ... */ }

        // Khởi chạy
        window.onload = init;
    </script>
</body>
</html>
