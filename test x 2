	end

	local targetPlayer = findTargetPlayer(inputName)
	if not targetPlayer then
		warn("❌ Không tìm thấy người chơi nào khớp với: " .. inputName)
		return
	end

	if targetPlayer == player then
		warn("❌ Bạn không thể tự dịch chuyển đến chính mình!")
		return
	end

	local speed = tonumber(speedBox.Text) or SPEED
	local x = tonumber(offsetX.Text) or 0
	local y = tonumber(offsetY.Text) or 10
	local z = tonumber(offsetZ.Text) or 0
	local offset = Vector3.new(x, y, z)

	print("🚀 Đang đuổi theo: " .. targetPlayer.Name .. " | Tốc độ: " .. speed)
	moveToPlayerSmooth(targetPlayer, speed, offset)
end)

