        }

        @keyframes slideIn { from { transform: translateX(150%); } }
        @keyframes slideOut { to { transform: translateX(150%); opacity: 0; } }
    </style>
</head>
<body>

    <div class="header">
        <span class="logo">🏚️</span>
        <span class="title">Homeless Life</span>
        <span class="player-count">
            <span class="live-dot"></span>
            <span id="onlineCount">0</span> online
        </span>
    </div>

    <div class="main">
        <div class="map" id="mapContainer">
            <canvas id="gameCanvas"></canvas>
        </div>

        <div class="sidebar">
            <div class="sidebar-header">
                <h3><i class="fa-solid fa-rocket"></i> Bay đến người chơi</h3>
                <div class="fly-box">
                    <input type="text" id="flyInput" class="fly-input" placeholder="Nhập tên người chơi..." autocomplete="off">
                    <button class="btn-fly" id="btnFly" onclick="flyToPlayer()">
                        <i class="fa-solid fa-rocket"></i> Bay
                    </button>
                    <div class="suggestions" id="suggestions"></div>
                </div>
            </div>
            <div class="player-list" id="playerList"></div>
        </div>
    </div>

    <div id="notiContainer"></div>

    <script>
        // Cache DOM
        const DOM = {
            canvas: document.getElementById('gameCanvas'),
            mapContainer: document.getElementById('mapContainer'),
            flyInput: document.getElementById('flyInput'),
            suggestions: document.getElementById('suggestions'),
            btnFly: document.getElementById('btnFly'),
            playerList: document.getElementById('playerList'),
            onlineCount: document.getElementById('onlineCount')
        };

        const ctx = DOM.canvas.getContext('2d');

        let players = [];
        let myX = 400, myY = 300;
        let isFlying = false;
        let flyStartTime = 0;
        let flyDuration = 1100;
        let flyStartX = 0, flyStartY = 0;
        let targetX = 0, targetY = 0;
        let flyTargetPlayer = null;

        const locations = ['Công viên','Ga tàu','Cầu vượt','Bến xe','Phố cổ','TTTM','Bãi xe','Công trường','Bờ sông','Ổ chuột'];
        const avatars = ['🧔','👩','👨','🧑','👴','👵','🧒','👦','👧','🧙'];
        const colors = ['#f0883e','#3fb950','#a371f7','#58a6ff','#d2991d','#f85149'];

        let obstacles = [];
        let animationFrame = null;

        function resizeCanvas() {
            DOM.canvas.width = DOM.mapContainer.clientWidth;
            DOM.canvas.height = DOM.mapContainer.clientHeight;
        }

        function generateObstacles() {
            obstacles = [
                {x:150,y:150,w:80,h:60,emoji:'🏠',color:'#8B7355'},
                {x:400,y:100,w:70,h:90,emoji:'🏢',color:'#708090'},
                {x:650,y:250,w:65,h:55,emoji:'🏪',color:'#CD853F'},
                {x:200,y:400,w:50,h:50,emoji:'🌳',color:'#228B22'},
                {x:550,y:380,w:75,h:50,emoji:'🏗️',color:'#A0522D'}
            ];
        }

        function generatePlayers() {
            const names = ['ShadowWalker','NightHawk','StreetKing','UrbanFox','CityWolf','DarkRider','AlleyCat','BridgeTroll'];
            players = names.map((name, i) => ({
                id: i + 1,
                name,
                avatar: avatars[i % avatars.length],
                color: colors[i % colors.length],
                x: 100 + Math.random() * (DOM.canvas.width - 200),
                y: 100 + Math.random() * (DOM.canvas.height - 200),
                level: Math.floor(Math.random() * 45) + 5,
                location: locations[i % locations.length]
            }));
        }

        function draw() {
            ctx.clearRect(0, 0, DOM.canvas.width, DOM.canvas.height);

            // Grid
            ctx.strokeStyle = 'rgba(48,54,61,0.3)';
            ctx.lineWidth = 1;
            for (let x = 0; x < DOM.canvas.width; x += 50) {
                ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, DOM.canvas.height); ctx.stroke();
            }
            for (let y = 0; y < DOM.canvas.height; y += 50) {
                ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(DOM.canvas.width, y); ctx.stroke();
            }

            // Obstacles
            obstacles.forEach(obs => {
                ctx.fillStyle = obs.color + '50';
                ctx.fillRect(obs.x, obs.y, obs.w, obs.h);
                ctx.strokeStyle = obs.color;
                ctx.strokeRect(obs.x, obs.y, obs.w, obs.h);
                ctx.font = '26px sans-serif';
                ctx.fillStyle = '#fff';
                ctx.textAlign = 'center';
                ctx.fillText(obs.emoji, obs.x + obs.w/2, obs.y + obs.h/2 + 10);
            });

            // Other Players
            players.forEach(p => {
                const dist = Math.hypot(p.x - myX, p.y - myY);
                
                // Shadow
                ctx.fillStyle = 'rgba(0,0,0,0.4)';
                ctx.beginPath();
                ctx.arc(p.x + 3, p.y + 3, 16, 0, Math.PI * 2);
                ctx.fill();

                // Body
                const grad = ctx.createRadialGradient(p.x - 4, p.y - 4, 4, p.x, p.y, 16);
                grad.addColorStop(0, p.color);
                grad.addColorStop(1, '#1a1a2e');
                ctx.fillStyle = grad;
                ctx.beginPath();
                ctx.arc(p.x, p.y, 16, 0, Math.PI * 2);
                ctx.fill();

                ctx.fillStyle = '#fff';
                ctx.font = '18px sans-serif';
                ctx.textAlign = 'center';
                ctx.textBaseline = 'middle';
                ctx.fillText(p.avatar, p.x, p.y);

                // Name + Distance
                ctx.fillStyle = '#fff';
                ctx.font = 'bold 10px sans-serif';
                ctx.fillText(p.name, p.x, p.y + 32);
                ctx.fillStyle = '#8b949e';
                ctx.font = '9px sans-serif';
                ctx.fillText(`${Math.round(dist * 0.6)}m`, p.x, p.y + 44);
            });

            // My Player + Flying Animation
            const progress = isFlying ? Math.min(1, (Date.now() - flyStartTime) / flyDuration) : 1;
            const eased = 1 - Math.pow(1 - progress, 3);
            const currentX = isFlying ? flyStartX + (targetX - flyStartX) * eased : myX;
            const currentY = isFlying ? flyStartY + (targetY - flyStartY) * eased : myY;

            // Glow
            const glow = ctx.createRadialGradient(currentX, currentY, 15, currentX, currentY, 55);
            glow.addColorStop(0, 'rgba(88,166,255,0.7)');
            glow.addColorStop(1, 'rgba(88,166,255,0)');
            ctx.fillStyle = glow;
            ctx.beginPath();
            ctx.arc(currentX, currentY, 55, 0, Math.PI * 2);
            ctx.fill();

            // Body
            ctx.fillStyle = '#58a6ff';
            ctx.beginPath();
            ctx.arc(currentX, currentY, 20, 0, Math.PI * 2);
            ctx.fill();

            ctx.fillStyle = '#fff';
            ctx.font = '22px sans-serif';
            ctx.fillText('🧑', currentX, currentY);

            ctx.fillStyle = '#fff';
            ctx.font = 'bold 11px sans-serif';
            ctx.fillText('BẠN', currentX, currentY + 32);

            // Trail
            if (isFlying) {
                for (let i = 0; i < 6; i++) {
                    const tp = Math.max(0, progress - i * 0.08);
                    const tx = flyStartX + (targetX - flyStartX) * (1 - Math.pow(1 - tp, 3));
                    const ty = flyStartY + (targetY - flyStartY) * (1 - Math.pow(1 - tp, 3));
                    ctx.fillStyle = `rgba(88,166,255,${0.6 - i * 0.1})`;
                    ctx.beginPath();
                    ctx.arc(tx, ty, 4 - i * 0.3, 0, Math.PI * 2);
                    ctx.fill();
                }
            }

            // Update position when flight ends
            if (isFlying && progress >= 1) {
                myX = targetX;
                myY = targetY;
                isFlying = false;
                DOM.btnFly.disabled = false;
                DOM.btnFly.innerHTML = `<i class="fa-solid fa-rocket"></i> Bay`;
                
                if (flyTargetPlayer) {
                    showNotification(`✅ Đã bay đến ${flyTargetPlayer.name}!`, flyTargetPlayer.location);
                    flyTargetPlayer = null;
                }
                updateUI();
            }
        }

        function gameLoop() {
            draw();
            animationFrame = requestAnimationFrame(gameLoop);
        }

        function startFly(player) {
            if (isFlying) return;

            flyTargetPlayer = player;
            flyStartX = myX;
            flyStartY = myY;
            targetX = player.x;
            targetY = player.y;
            flyStartTime = Date.now();
            isFlying = true;

            DOM.btnFly.disabled = true;
            DOM.btnFly.innerHTML = `<i class="fa-solid fa-spinner fa-spin"></i> Đang bay...`;

            highlightCard(player.id);
        }

        function highlightCard(id) {
            document.querySelectorAll('.player-card').forEach(c => c.classList.remove('target'));
            const card = document.getElementById(`card-${id}`);
            if (card) {
                card.classList.add('target');
                setTimeout(() => card.classList.remove('target'), 1600);
            }
        }

        function flyToPlayer() {
            const name = DOM.flyInput.value.trim();
            if (!name) return showNotification('⚠️ Vui lòng nhập tên!');

            const player = players.find(p => p.name.toLowerCase() === name.toLowerCase());
            if (!player) return showNotification('❌ Không tìm thấy người chơi!');

            startFly(player);
            DOM.flyInput.value = '';
            DOM.suggestions.classList.remove('active');
        }

        function flyToPlayerById(id) {
            const player = players.find(p => p.id === id);
            if (player) startFly(player);
        }

        function updateUI() {
            DOM.onlineCount.textContent = players.length;
            renderPlayerList();
        }

        function renderPlayerList() {
            const sorted = [...players].sort((a, b) => 
                Math.hypot(a.x - myX, a.y - myY) - Math.hypot(b.x - myX, b.y - myY)
            );

            DOM.playerList.innerHTML = sorted.map(p => {
                const dist = Math.round(Math.hypot(p.x - myX, p.y - myY) * 0.6);
                return `
                    <div class="player-card" id="card-\( {p.id}" onclick="flyToPlayerById( \){p.id})">
                        <div class="player-avatar" style="background:\( {p.color}25;color: \){p.color}">${p.avatar}</div>
                        <div style="flex:1">
                            <div style="font-weight:600">\( {p.name} <span style="font-size:10px;color:#a371f7">Lv. \){p.level}</span></div>
                            <div style="font-size:12px;color:var(--text-secondary)">📍 ${p.location} · ${dist}m</div>
                        </div>
                        <button class="btn-fly" style="padding:6px 12px;font-size:12px" onclick="event.stopPropagation();flyToPlayerById(${p.id})">
                            Bay
                        </button>
                    </div>
                `;
            }).join('');
        }

        function setupListeners() {
            const input = DOM.flyInput;
            const suggestions = DOM.suggestions;

            input.addEventListener('input', () => {
                const val = input.value.toLowerCase().trim();
                if (!val) {
                    suggestions.classList.remove('active');
                    return;
                }

                const matches = players.filter(p => p.name.toLowerCase().includes(val));
                suggestions.innerHTML = matches.length ? 
                    matches.map(p => `
                        <div class="suggestion-item" onclick="selectPlayer('${p.name}')">
                            \( {p.avatar} <span> \){p.name}</span>
                            <span style="margin-left:auto;color:#8b949e">📍 ${p.location}</span>
                        </div>
                    `).join('') : 
                    '<div class="suggestion-item" style="color:#8b949e">Không tìm thấy</div>';
                suggestions.classList.add('active');
            });

            input.addEventListener('keypress', e => {
                if (e.key === 'Enter') flyToPlayer();
            });

            document.addEventListener('click', e => {
                if (!e.target.closest('.fly-box')) suggestions.classList.remove('active');
            });
        }

        function selectPlayer(name) {
            DOM.flyInput.value = name;
            DOM.suggestions.classList.remove('active');
            flyToPlayer();
        }

        function showNotification(msg, detail = '') {
            const noti = document.createElement('div');
            noti.className = 'noti';
            noti.innerHTML = `
                <i class="fa-solid fa-circle-check" style="color:var(--accent-blue)"></i>
                <div><strong>\( {msg}</strong> \){detail ? `<br><small>${detail}</small>` : ''}</div>
            `;
            document.getElementById('notiContainer').appendChild(noti);
            setTimeout(() => noti.remove(), 2600);
        }

        // Random movement
        function movePlayers() {
            players.forEach(p => {
                p.x += (Math.random() - 0.5) * 35;
                p.y += (Math.random() - 0.5) * 35;
                p.x = Math.max(40, Math.min(DOM.canvas.width - 40, p.x));
                p.y = Math.max(40, Math.min(DOM.canvas.height - 40, p.y));
            });
        }

        // Init
        function init() {
            resizeCanvas();
            window.addEventListener('resize', () => {
                resizeCanvas();
                generatePlayers(); // reposition players
            });

            generateObstacles();
            generatePlayers();
            setupListeners();
            updateUI();

            setInterval(() => {
                movePlayers();
                updateUI();
            }, 1800);

            gameLoop();
        }

        window.onload = init;
    </script>
</body>
</html>
