-- ==================== HÀM TÌM NGƯỜI CHƠI ====================
local function findTargetPlayer(namePart)
	namePart = namePart:lower()
	for _, p in ipairs(Players:GetPlayers()) do
		if p.Name:lower():sub(1, #namePart) == namePart or p.DisplayName:lower():sub(1, #namePart) == namePart then
			return p
		end
	end
	return nil
end

-- ==================== HÀM DI CHUYỂN SIÊU MƯỢT ====================
local function moveToPlayerSmooth(targetPlayer, customSpeed, customOffset)
	-- Nếu đang di chuyển dở từ lần bấm trước, hủy bỏ nó đi
	if currentMoveConnection then
		currentMoveConnection:Disconnect()
		currentMoveConnection = nil
	end

	local speed = customSpeed or SPEED
	local offset = customOffset or OFFSET

	local character = player.Character
	local rootPart = character and character:FindFirstChild("HumanoidRootPart")
	
	if not rootPart then
		warn("❌ Không tìm thấy HumanoidRootPart của bạn!")
		return
	end

	-- Tạo kết nối vòng lặp vật lý mượt mà từng khung hình
	currentMoveConnection = RunService.Heartbeat:Connect(function(deltaTime)
		-- Kiểm tra xem mục tiêu có còn tồn tại không
		if not targetPlayer or not targetPlayer.Character or not targetPlayer.Character:FindFirstChild("HumanoidRootPart") then
			warn("❌ Mục tiêu đã mất dấu hoặc thoát game!")
			if currentMoveConnection then currentMoveConnection:Disconnect() end
			rootPart.Anchored = false
			return
		end

		local targetRoot = targetPlayer.Character.HumanoidRootPart
		local targetPosition = targetRoot.Position + offset
		local currentPosition = rootPart.Position

		local direction = (targetPosition - currentPosition)
		local distance = direction.Magnitude

		-- Tính toán quãng đường đi được trong khung hình này dựa trên Speed
		local moveStep = speed * deltaTime

		if distance <= moveStep then
			-- Đã đến rất gần mục tiêu, đặt CFrame chính xác và dừng vòng lặp
			rootPart.CFrame = CFrame.new(targetPosition)
			rootPart.Anchored = false
			currentMoveConnection:Disconnect()
			currentMoveConnection = nil
			print("✅ Đã đến nơi an toàn!")
		else
			-- Di chuyển dần dần tới đích mà không bị giật
			rootPart.Anchored = true -- Giữ không cho rớt vật lý tự do
			rootPart.CFrame = CFrame.new(currentPosition + direction.Unit * moveStep)
		end
	end)
end

