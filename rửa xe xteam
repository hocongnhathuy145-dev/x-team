-- ===== HÀM BAY LƠ LỬNG XUYÊN TƯỜNG =====
local function getStandPos(hrp)
	if not hrp then return nil end
	local dir = (CarPos - hrp.Position).Unit
	local targetPos = CarPos - dir * StandDistance
	return Vector3.new(targetPos.X, FlyHeight, targetPos.Z)
end

local function flyToCar(hrp, hum)
	if Moving then return end
	Moving = true
	
	-- Tắt animation đi bộ
	hum.WalkSpeed = 0
	hum.JumpPower = 0
	
	-- Đưa nhân vật lên độ cao bay
	local startPos = hrp.Position
	
	-- Bay lên độ cao lơ lửng
	if math.abs(startPos.Y - FlyHeight) > 1 then
		local steps = math.ceil(math.abs(startPos.Y - FlyHeight) / 3)
		for i = 1, steps do
			local progress = i / steps
			local currentY = startPos.Y + (FlyHeight - startPos.Y) * progress
			hrp.CFrame = CFrame.new(Vector3.new(startPos.X, currentY, startPos.Z))
			task.wait(0.005)
		end
	end
	
	-- Bay ngang đến xe
	while AutoWash and Moving do
		local currentPos = hrp.Position
		local standPos = getStandPos(hrp)
		
		if not standPos then break end
		
		local flatCurrent = Vector3.new(currentPos.X, 0, currentPos.Z)
		local flatTarget = Vector3.new(standPos.X, 0, standPos.Z)
		local distance = (flatCurrent - flatTarget).Magnitude
		
		-- Đã đến nơi
		if distance < 2 then
			-- Hạ xuống đất
			local targetY = CarPos.Y
			hrp.CFrame = CFrame.new(Vector3.new(standPos.X, targetY, standPos.Z))
			break
		end
		
		-- Tính hướng bay ngang
		local direction = (flatTarget - flatCurrent).Unit
		local step = StepSize * (MoveSpeed / 28)
		
		-- Vị trí mới (bay lơ lửng)
		local newPos = Vector3.new(
			currentPos.X + direction.X * step,
			FlyHeight,
			currentPos.Z + direction.Z * step
		)
		
		-- Cập nhật vị trí
		hrp.CFrame = CFrame.new(newPos)
		
		-- Delay theo tốc độ
		task.wait(StepDelay * (28 / MoveSpeed))
	end
	
	-- Reset humanoid
	hum.WalkSpeed = 16
	hum.JumpPower = 50
	Moving = false
end

-- ===== AUTO LAU XE MAIN LOOP =====
task.spawn(function()
	while true do
		task.wait(0.2)
		if not AutoWash then continue end

		local char = Player.Character
		local hrp = char and char:FindFirstChild("HumanoidRootPart")
		local hum = char and char:FindFirstChildOfClass("Humanoid")
		if not (hrp and hum) then continue end

		-- Auto Respawn khi hết máu hoặc hunger
		local hunger = char:FindFirstChild("Hunger")
		local health = hum.Health
		
		if ((hunger and hunger.Value <= 0) or health <= 0) and not ForceRespawn then
			if AutoRespawn and SavedPosition then
				ForceRespawn = true
				hum.Health = 0
			end
			continue
		end

		-- Bắt đầu bay
		local standPos = getStandPos(hrp)
		if standPos then
			local flatDist = (Vector3.new(hrp.Position.X, 0, hrp.Position.Z) - Vector3.new(standPos.X, 0, standPos.Z)).Magnitude
			if flatDist > 2 and not Moving then
				flyToCar(hrp, hum)
			end
		end
	end
end)

-- ===== AUTO RESPAWN VỀ VỊ TRÍ ĐÃ LƯU =====
Player.CharacterAdded:Connect(function(char)
	if ForceRespawn and AutoRespawn and SavedPosition then
		-- Đợi character load hoàn toàn
		repeat task.wait(0.1) until char:FindFirstChild("HumanoidRootPart") and char:FindFirstChildOfClass("Humanoid")
		
		local hrp = char:FindFirstChild("HumanoidRootPart")
		local hum = char:FindFirstChildOfClass("Humanoid")
		
		if hrp and hum then
			-- Đợi 1 chút để game load xong
			task.wait(0.3)
			
			-- Teleport về vị trí đã lưu
			hrp.CFrame = SavedPosition
			
			-- Reset humanoid
			hum.WalkSpeed = 16
			hum.JumpPower = 50
		end
	end
	
	ForceRespawn = false
	Moving = false
end)

