-- ===== AUTO LAU XE – FIX ĐỨNG SÁT XE =====
local function getStandPos(hrp)
	local dir = (hrp.Position - CarPos).Unit
	return CarPos + dir * StandDistance
end

local function moveStraight(hrp)
	if Moving then return end
	Moving = true

	local standPos = getStandPos(hrp)
	local dist = (standPos - hrp.Position).Magnitude
	local time = dist / MoveSpeed

	local tween = TweenService:Create(
		hrp,
		TweenInfo.new(time, Enum.EasingStyle.Linear),
		{CFrame = CFrame.new(standPos, CarPos)}
	)

	tween:Play()
	tween.Completed:Wait()
	Moving = false
end

task.spawn(function()
	while true do
		task.wait(0.25)
		if not AutoWash then continue end

		local char = Player.Character
		local hrp = char and char:FindFirstChild("HumanoidRootPart")
		local hum = char and char:FindFirstChildOfClass("Humanoid")
		if not (hrp and hum) then continue end

		local hunger = char:FindFirstChild("Hunger")
		if hunger and hunger.Value <= 0 and not ForceRespawn then
			ForceRespawn = true
			hum.Health = 0
			continue
		end

		if (getStandPos(hrp) - hrp.Position).Magnitude > 0.3 then
			moveStraight(hrp)
		end
	end
end)

Player.CharacterAdded:Connect(function()
	ForceRespawn = false
	Moving = false
end)

-- ===== AUTO E =====
task.spawn(function()
