local function UpdateList()
    for _, c in ipairs(plist:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player then
            local pb = Instance.new("TextButton", plist)
            pb.Size = UDim2.new(1,-4,0,26); pb.Font = Enum.Font.Gotham; pb.TextSize = 8
            pb.TextXAlignment = Enum.TextXAlignment.Left; Instance.new("UICorner", pb)
            if Config.HitboxWhitelist[p.Name] then
                pb.Text = " [X] " .. p.DisplayName
                pb.TextColor3 = Color3.fromRGB(255,180,180); pb.BackgroundColor3 = Color3.fromRGB(160,30,30)
            else
                pb.Text = " " .. p.DisplayName
                pb.TextColor3 = Color3.fromRGB(200,200,200); pb.BackgroundColor3 = Color3.fromRGB(38,38,38)
            end
            pb.MouseButton1Click:Connect(function()
                Config.HitboxWhitelist[p.Name] = not Config.HitboxWhitelist[p.Name]; UpdateList()
            end)
            pb.MouseButton2Click:Connect(function()
                targetCache = p; nameBox.Text = p.Name
                if Config.IsBam then StopBam(); StartBam(p, Config.OX, Config.OY, Config.OZ)
                    teleBtn.Text = "BÁM: " .. p.Name; teleBtn.BackgroundColor3 = Color3.fromRGB(0,170,0) end
            end)
        end
    end
    plist.CanvasSize = UDim2.new(0,0,0, pll.AbsoluteContentSize.Y + 5)
end
Players.PlayerAdded:Connect(UpdateList)
Players.PlayerRemoving:Connect(function(p)
    if Config.HitboxWhitelist[p.Name] then Config.HitboxWhitelist[p.Name] = nil end
    if targetCache == p then targetCache = nil end
    UpdateList()
end)
UpdateList()

