local function Lbl(parent, text)
    local l = Instance.new("TextLabel", parent)
    l.Size = UDim2.new(1,0,0,20); l.Text = text; l.TextColor3 = Color3.fromRGB(255,200,0)
    l.BackgroundTransparency = 1; l.Font = Enum.Font.GothamBold; l.TextSize = 10
    l.TextXAlignment = Enum.TextXAlignment.Left
    return l
end

local function Set(parent, label, default, cb, minV, maxV)
    local r = Instance.new("Frame", parent); r.Size = UDim2.new(1,0,0,28); r.BackgroundTransparency = 1
    local lb = Instance.new("TextLabel", r); lb.Size = UDim2.new(0.35,0,1,0)
    lb.Text = label; lb.TextColor3 = Color3.fromRGB(200,200,200); lb.Font = Enum.Font.Gotham
    lb.TextSize = 9; lb.BackgroundTransparency = 1; lb.TextXAlignment = Enum.TextXAlignment.Left
    
    local mn = Instance.new("TextButton", r); mn.Size = UDim2.new(0.15,0,1,0); mn.Position = UDim2.new(0.35,0,0,0)
    mn.Text = "-"; mn.BackgroundColor3 = Color3.fromRGB(150,40,40); mn.TextColor3 = Color3.fromRGB(255,255,255)
    mn.Font = Enum.Font.GothamBlack; mn.TextSize = 12; Instance.new("UICorner", mn)
    
    local bx = Instance.new("TextBox", r); bx.Size = UDim2.new(0.3,0,1,0); bx.Position = UDim2.new(0.51,0,0,0)
    bx.Text = tostring(default); bx.BackgroundColor3 = Color3.fromRGB(30,30,30)
    bx.TextColor3 = Color3.fromRGB(255,255,255); bx.Font = Enum.Font.GothamBold; bx.TextSize = 9
    Instance.new("UICorner", bx)
    
    local pl = Instance.new("TextButton", r); pl.Size = UDim2.new(0.15,0,1,0); pl.Position = UDim2.new(0.82,0,0,0)
    pl.Text = "+"; pl.BackgroundColor3 = Color3.fromRGB(40,150,40); pl.TextColor3 = Color3.fromRGB(255,255,255)
    pl.Font = Enum.Font.GothamBlack; pl.TextSize = 12; Instance.new("UICorner", pl)
    
    local function clamp(v)
        if minV and maxV then return math.max(minV, math.min(v, maxV)) end
        return v
    end
    
    bx:GetPropertyChangedSignal("Text"):Connect(function()
        local n = tonumber(bx.Text); if n then cb(clamp(n)) end
    end)
    mn.MouseButton1Click:Connect(function()
        local n = (tonumber(bx.Text) or default) - 1; n = clamp(n); bx.Text = tostring(n); cb(n)
    end)
    pl.MouseButton1Click:Connect(function()
        local n = (tonumber(bx.Text) or default) + 1; n = clamp(n); bx.Text = tostring(n); cb(n)
    end)
end

local function Btn(parent, text, callback)
    local b = Instance.new("TextButton", parent)
    b.Size = UDim2.new(1,0,0,32); b.Text = text; b.BackgroundColor3 = Color3.fromRGB(50,50,50)
    b.TextColor3 = Color3.fromRGB(255,255,255); b.Font = Enum.Font.GothamBold; b.TextSize = 9
    Instance.new("UICorner", b)
    b.MouseButton1Click:Connect(function() callback(b) end)
    return b
end

