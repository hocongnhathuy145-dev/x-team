RunService.RenderStepped:Connect(function()
    if Config.IsSpeedHack and player.Character and player.Character:FindFirstChildOfClass("Humanoid") then
        player.Character:FindFirstChildOfClass("Humanoid").WalkSpeed = Config.CustomSpeed
    end
    if Config.IsJumpPower and player.Character and player.Character:FindFirstChildOfClass("Humanoid") then
        player.Character:FindFirstChildOfClass("Humanoid").JumpPower = Config.JumpPower
    end
    if Config.IsHitboxExtend then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local root = p.Character.HumanoidRootPart
                if Config.HitboxWhitelist[p.Name] then
                    root.Size = Vector3.new(2,2,1); root.Transparency = 1
                else
                    root.Size = Vector3.new(Config.HitboxSize, Config.HitboxSize, Config.HitboxSize)
                    root.Transparency = 0.5; root.Color = Color3.fromRGB(255,255,0)
                end
            end
        end
    end
end)

RunService.Stepped:Connect(function(time, dt)
    if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then return end
    
    if Config.IsZicZac and not Config.IsBam and not isEscaping then
        local target = targetCache or FindTarget(nameBox.Text)
        if target then ProcessZicZac(target, dt) end
    end
    
    if Config.IsAutoEscape and not isEscaping and CheckHit() then
        targetCache = FindTarget(nameBox.Text); TriggerGroundEscape()
    end
end)

RunService.Heartbeat:Connect(function()
    if Config.IsAutoClick then
        pcall(function()
            local cr = game:GetService("ReplicatedStorage"):FindFirstChild("CombatRemote") or game:GetService("ReplicatedStorage"):FindFirstChild("Combat")
            if cr then cr:FireServer("M1"); cr:FireServer("M2") end
        end)
    end
    if Config.IsAutoReblock then
        pcall(function()
            local cr = game:GetService("ReplicatedStorage"):FindFirstChild("CombatRemote") or game:GetService("ReplicatedStorage"):FindFirstChild("Combat")
            if cr then cr:FireServer("Block", true) end
        end)
    end
end)

player.CharacterAdded:Connect(function(char)
    StopBam(); isEscaping = false; lastHealth = 100
    task.wait(0.5)
    if Config.IsBam and targetCache then StartBam(targetCache, Config.OX, Config.OY, Config.OZ) end
    if Config.IsJumpPower and char:FindFirstChildOfClass("Humanoid") then
        char:FindFirstChildOfClass("Humanoid").JumpPower = Config.JumpPower
    end
end)
