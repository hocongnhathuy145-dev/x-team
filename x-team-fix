-- ==================== TÌM MỤC TIÊU ====================
local function FindTarget(searchText)
    if searchText and searchText ~= "" and searchText ~= "nhập tên..." and searchText ~= "nhập tên mục tiêu..." then
        local lower = searchText:lower()
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player and (p.Name:lower():find(lower) or p.DisplayName:lower():find(lower)) then return p end
        end
    end
    
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end
    local hrp = char.HumanoidRootPart
    
    local closest, closestDist = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local dist = (p.Character.HumanoidRootPart.Position - hrp.Position).Magnitude
            if dist < closestDist then closestDist = dist; closest = p end
        end
    end
    return closest
end

-- ==================== CHECK MÁU ====================
local function CheckHit()
    local char = player.Character
    if not char then return false end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum then
        if hum.Health < lastHealth then lastHealth = hum.Health; return true end
        lastHealth = hum.Health
    end
    return false
end

-- ==================== NO CLIP ====================
local function EnableNoclip()
    if noclipConn then return end
    noclipConn = RunService.Stepped:Connect(function()
        pcall(function()
            local char = player.Character
            if char then for _, v in ipairs(char:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide = false end end end
        end)
    end)
end

local function DisableNoclip()
    if noclipConn then noclipConn:Disconnect(); noclipConn = nil end
end

-- ==================== BÁM ====================
local function StartBam(target, ox, oy, oz)
    if bamConn then bamConn:Disconnect(); bamConn = nil end
    bamActive = true
    
    if not Config.IsNoclip then
        Config.IsNoclip = true; EnableNoclip()
        if noclipBtn then noclipBtn.Text = "NO CLIP: BẬT"; noclipBtn.BackgroundColor3 = Color3.fromRGB(0,150,0) end
    end
    
    bamConn = RunService.RenderStepped:Connect(function(dt)
        if not bamActive then return end
        local char = player.Character
        if not char or not char:FindFirstChild("HumanoidRootPart") or not char:FindFirstChildOfClass("Humanoid") then return end
        local hrp = char.HumanoidRootPart; local hum = char:FindFirstChildOfClass("Humanoid")
        pcall(function() hrp.CanCollide = false end)
        
        if not target or not target.Character or not target.Character:FindFirstChild("HumanoidRootPart") then
            target = FindTarget(nameBox and nameBox.Text or "")
            if not target then return end; targetCache = target
        end
        
        local targetHrp = target.Character.HumanoidRootPart
        local offset = targetHrp.CFrame:VectorToWorldSpace(Vector3.new(ox, oy, oz))
        local destPos = targetHrp.Position + offset
        local dist = (destPos - hrp.Position).Magnitude
        
        if dist > 1 then
            local moveDir = (destPos - hrp.Position).Unit
            hum.WalkSpeed = Config.BamSpeed; hum:Move(moveDir, false)
            hrp.AssemblyLinearVelocity = moveDir * math.min(Config.BamSpeed * 0.5, 28)
            pcall(function() hrp:SetNetworkOwner(player) end)
        else
            hum:Move(Vector3.zero, false); hrp.AssemblyLinearVelocity = Vector3.zero
        end
    end)
end

local function StopBam()
    bamActive = false
    if bamConn then bamConn:Disconnect(); bamConn = nil end
    pcall(function()
        local char = player.Character
        if char then
            if char:FindFirstChildOfClass("Humanoid") then char:FindFirstChildOfClass("Humanoid").WalkSpeed = 16 end
            if char:FindFirstChild("HumanoidRootPart") then char.HumanoidRootPart.AssemblyLinearVelocity = Vector3.zero end
        end
    end)
end

-- ==================== ESCAPE GỐC - GIỮ NGUYÊN CƠ CHẾ ====================
local function TriggerGroundEscape()
    if not Config.IsAutoEscape or isEscaping then return end
    
    local myChar = player.Character
    if not myChar or not myChar:FindFirstChild("HumanoidRootPart") then return end
    local hrp = myChar.HumanoidRootPart
    local hum = myChar:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return end

    -- Tìm mục tiêu
    local targetPlayer = targetCache or FindTarget(nameBox and nameBox.Text or "")
    if not targetPlayer or not targetPlayer.Character or not targetPlayer.Character:FindFirstChild("HumanoidRootPart") then return end
    local targetHrp = targetPlayer.Character.HumanoidRootPart

    isEscaping = true

    -- LƯU TRẠNG THÁI BÁM
    local wasBam = Config.IsBam
    Config.IsBam = false
    if wasBam then StopBam() end

    -- SET NETWORK OWNER (GIỐNG BẢN GỐC)
    pcall(function()
        settings().Physics.AllowSleep = false
        for _, part in pairs(myChar:GetDescendants()) do
            if part:IsA("BasePart") and part:CanSetNetworkOwnership() then
                part:SetNetworkOwner(player)
            end
        end
    end)
    
    hrp.AssemblyLinearVelocity = Vector3.zero
    hrp.AssemblyAngularVelocity = Vector3.zero
    
    local originalY = hrp.Position.Y
    
    -- BAY QUA TRÁI (TRỤC X ÂM) + ZIC ZAC LOẠN XẠ
    local pushDirX = -1
    local startTime = tick()
    local escapeLoop
    local zicZacSeed = math.random() * 100
    local zicZacSpeed = 20 + math.random() * 15
    
    escapeLoop = RunService.Heartbeat:Connect(function(deltaTime)
        if not hrp or not targetHrp or hum.Health <= 0 then
            if escapeLoop then escapeLoop:Disconnect() end
            isEscaping = false
            Config.IsBam = wasBam
            if wasBam and targetPlayer then StartBam(targetPlayer, Config.OX, Config.OY, Config.OZ) end
            return
        end
        
        local elapsed = tick() - startTime
        
        if elapsed >= Config.EscapeDuration then
            if escapeLoop then escapeLoop:Disconnect() end
            
            pcall(function()
                for _, part in pairs(myChar:GetDescendants()) do
                    if part:IsA("BasePart") and part:CanSetNetworkOwnership() then
                        part:SetNetworkOwner(nil)
                    end
                end
            end)
            
            hrp.AssemblyLinearVelocity = Vector3.zero
            hrp.AssemblyAngularVelocity = Vector3.zero
            
            isEscaping = false
            
            -- TRẢ QUYỀN BÁM
            if wasBam then
                Config.IsBam = true
                StartBam(targetPlayer, Config.OX, Config.OY, Config.OZ)
                if teleBtn then
                    teleBtn.Text = "BÁM: " .. targetPlayer.Name
                    teleBtn.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
                end
            end
            return
        end
        
        -- ÉP NETWORK OWNER
        pcall(function()
            for _, part in pairs(myChar:GetDescendants()) do
                if part:IsA("BasePart") and part:CanSetNetworkOwnership() then
                    part:SetNetworkOwner(player)
                end
            end
        end)
        
        -- ZIC ZAC LOẠN XẠ (GIỐNG BẢN GỐC)
        local zicZacTime = elapsed * zicZacSpeed
        local zShake1 = math.sin(zicZacTime * 1.3 + zicZacSeed) * Config.EscapeZicZacIntensity
        local zShake2 = math.cos(zicZacTime * 2.7 + zicZacSeed * 1.5) * (Config.EscapeZicZacIntensity * 0.5)
        local zShake3 = math.sin(zicZacTime * 4.1 + zicZacSeed * 2.3) * (Config.EscapeZicZacIntensity * 0.25)
        
        if math.random(1, 20) == 1 then
            zicZacSpeed = 18 + math.random() * 20
        end
        
        local zShakeTotal = zShake1 + zShake2 + zShake3
        
        -- LỰC ĐẨY QUA TRÁI + ZIC ZAC
        local pushStrength = Config.EscapePushForce * (1 - elapsed / Config.EscapeDuration * 0.3)
        local velX = pushDirX * pushStrength
        local velZ = zShakeTotal * 10
        
        local totalVelocity = Vector3.new(velX, 0, velZ)
        
        local maxSpeed = Config.EscapePushForce * 1.5
        if totalVelocity.Magnitude > maxSpeed then
            totalVelocity = totalVelocity.Unit * maxSpeed
        end
        
        hrp.AssemblyLinearVelocity = totalVelocity
        hrp.AssemblyAngularVelocity = Vector3.zero
        
        -- GIỮ ĐỘ CAO
        hrp.CFrame = CFrame.new(Vector3.new(hrp.Position.X, originalY, hrp.Position.Z))
    end)
end

-- ==================== ZIC ZAC ====================
local function ProcessZicZac(target, dt)
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") or not char:FindFirstChildOfClass("Humanoid") then return end
    local hrp = char.HumanoidRootPart; local hum = char:FindFirstChildOfClass("Humanoid")
    
    if not target or not target.Character or not target.Character:FindFirstChild("HumanoidRootPart") then return end
    local targetHrp = target.Character.HumanoidRootPart
    
    circleAngle = circleAngle + Config.ZZSpeed * dt
    upDownCounter = upDownCounter + 67 * dt
    
    local lightningStepX = math.sign(math.sin(circleAngle)) * math.abs(math.sin(circleAngle * 1.5))
    local lightningStepZ = math.sign(math.cos(circleAngle)) * math.abs(math.cos(circleAngle * 1.5))
    local jitterX = (math.noise(tick() * 22, 0, 0) * 4.5)
    local jitterZ = (math.noise(0, tick() * 22, 0) * 4.5)
    local jitterY = (math.noise(0, 0, tick() * 28) * (4.5 * 0.7))
    
    local ox = (lightningStepX * Config.ZZRange) + jitterX
    local oz = (lightningStepZ * Config.ZZRange) + jitterZ
    local oy = Config.OY + (math.sin(upDownCounter) * 5) + jitterY
    
    local offset = targetHrp.CFrame:VectorToWorldSpace(Vector3.new(ox, oy, oz))
    local destPos = targetHrp.Position + offset
    local dist = (destPos - hrp.Position).Magnitude
    
    if dist > 1 then
        local dir = (destPos - hrp.Position).Unit
        hum.WalkSpeed = 28; hum:Move(dir, false)
        hrp.AssemblyLinearVelocity = dir * 14
        pcall(function() hrp:SetNetworkOwner(player); hrp.CanCollide = false end)
    end
end

-- ==================== GUI ====================
local function MakeDraggable(gui)
    local dragging, dragInput, dragStart, startPos
    gui.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true; dragStart = input.Position; startPos = gui.Position
            input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false end end)
        end
    end)
    gui.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            TweenService:Create(gui, TweenInfo.new(0.1), {
                Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
            }):Play()
        end
    end)
end

